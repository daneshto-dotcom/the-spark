{
  "name": "spark",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "SPARK — Real-time multiplayer game of geometric emergence (Phase 1 prototype)",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build && node scripts/check-bundle-size.mjs",
    "size": "node scripts/check-bundle-size.mjs",
    "preview": "vite preview",
    "typecheck": "tsc -b --noEmit",
    "test": "vitest",
    "e2e": "playwright test",
    "e2e:headed": "playwright test --headed",
    "e2e:ui": "playwright test --ui",
    "probe-relays": "node scripts/probe-relays.mjs"
  },
  "dependencies": {
    "@trystero-p2p/core": "0.25.0",
    "@trystero-p2p/mqtt": "0.25.0",
    "@trystero-p2p/nostr": "0.25.0",
    "@trystero-p2p/torrent": "0.25.0",
    "pixi.js": "^8.5.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "typescript": "^5.4.0",
    "vite": "^6.4.2",
    "vitest": "^3.2.4"
  }
}
